/**
 * Theme App Extension – Liquid block for embedding the countdown widget.
 * This block is registered in the Shopify theme editor and renders
 * a container that the JS widget targets.
 *
 * Settings allow merchants to configure directly from the theme editor.
 */
{% comment %}
  Countdown Timer Block
  Renders a placeholder div and loads the widget script.
{% endcomment %}

<div
  id="countdown-timer-widget"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  style="min-height: 50px;"
>
  <!-- Timer renders here via JS – min-height prevents CLS -->
</div>

<script src="{{ 'countdown-widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Countdown Timer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "API URL",
      "default": "https://your-app-domain.com/api"
    }
  ]
}
{% endschema %}
